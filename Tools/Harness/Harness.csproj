<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>OptcgHarness</AssemblyName>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>
  <!-- Compiles the REAL, pure-C# engine (no UnityEngine deps) straight from Assets/, so the
       harness always tests the shipping engine. See README.md for run commands. -->
  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="CardLibraryLoader.cs" />
    <Compile Include="Scenarios.cs" />
    <Compile Include="EffectCoverage.cs" />
    <Compile Include="Invariants.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\GameEngine.cs" Link="Engine\GameEngine.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\GameState.cs" Link="Engine\GameState.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\CardData.cs" Link="Engine\CardData.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\IntermediateBot.cs" Link="Engine\Bot\IntermediateBot.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\ChampionBot.cs" Link="Engine\Bot\ChampionBot.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\GameClone.cs" Link="Engine\Bot\Search\GameClone.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\Evaluation.cs" Link="Engine\Bot\Search\Evaluation.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\LegalActions.cs" Link="Engine\Bot\Search\LegalActions.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\SearchBot.cs" Link="Engine\Bot\Search\SearchBot.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\TriggerUtilityPolicy.cs" Link="Engine\Bot\Search\TriggerUtilityPolicy.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\RemovalModel.cs" Link="Engine\Bot\Search\RemovalModel.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\DonOpportunityModel.cs" Link="Engine\Bot\Search\DonOpportunityModel.cs" />
    <Compile Include="..\..\Assets\Scripts\Engine\Bot\Search\BotDeterminizer.cs" Link="Engine\Bot\Search\BotDeterminizer.cs" />
  </ItemGroup>
</Project>
